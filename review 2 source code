<?php
// DATABASE CONNECTION
$conn = new mysqli("localhost", "root", "", "smart_campus");

if ($conn->connect_error) {
    die("Connection failed: " . $conn->connect_error);
}

// INSERT DATA
if ($_SERVER["REQUEST_METHOD"] == "POST") {
    $title = $_POST['title'];
    $description = $_POST['description'];
    $date = $_POST['event_date'];
    $venue = $_POST['venue'];

    $sql = "INSERT INTO events (title, description, event_date, venue)
            VALUES ('$title', '$description', '$date', '$venue')";

    $conn->query($sql);
}
?>

<!DOCTYPE html>
<html>
<head>
    <title>Smart Campus Event System</title>
</head>
<body>

<h2>Add Event</h2>

<form method="POST">
    Title: <input type="text" name="title" required><br><br>
    
