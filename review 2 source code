    Venue: <input type="text" name="venue" required><br><br>
    
    <button type="submit">Add Event</button>
</form>

<hr>

<h2>All Events</h2>

<table border="1">
<tr>
    <th>ID</th>
    <th>Title</th>
    <th>Description</th>
    <th>Date</th>
    <th>Venue</th>
</tr>

<?php
$result = $conn->query("SELECT * FROM events");

while($row = $result->fetch_assoc()) {
    echo "<tr>
        <td>{$row['id']}</td>
        <td>{$row['title']}</td>
        <td>{$row['description']}</td>
        <td>{$row['event_date']}</td>
        <td>{$row['venue']}</td>
    </tr>";
}
?>

</table>

</body>
